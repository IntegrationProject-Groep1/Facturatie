# RabbitMQ Configuration
RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_PORT=30000
RABBITMQ_USER=your_user
RABBITMQ_PASSWORD=your_pass
RABBITMQ_VHOST=/

# Queue Names (team-prefixed per shared vhost rules)
QUEUE_INCOMING=facturatie.incoming
QUEUE_FRONTEND=facturatie.to.frontend
QUEUE_DLQ=errors.facturatie
QUEUE_HEARTBEAT=heartbeat

# FOSSBilling API Configuration
BILLING_API_URL=https://facturatie.desiderius.me/api
BILLING_API_USERNAME=admin
BILLING_API_TOKEN=your-api-token
BILLING_WEB_URL=https://facturatie.desiderius.me

# Database Configuration
MYSQL_DATABASE=fossbilling
MYSQL_USER=fossbilling
MYSQL_PASSWORD=your-db-password
MYSQL_HOST=mysql
DB_HOST=mysql
DB_HOST=localhost

# Service Configuration
SERVICE_PORT=30010
